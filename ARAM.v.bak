//1
module ARAM(
    input [4:0] Dir,
    input EN,
    input [31:0] DatoE,
    output reg [31:0] DatoS
);
//2
//crear la memoria bidimencional
reg [31:0] MeM [0:31];

//3
initial 
	begin
        $readmemb("C:/Users/USUARIO/Documents/ArquitecturadeComputadoras/ROM/datos.txt", banco);
	end
    // Lectura
    always @(*) begin
        if (EN)
            begin
                MeM[Dir] = DatoE;
            end 
        else 
            begin
                DatoS = MeM[Dir];
            end
    end

endmodule